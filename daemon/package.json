{
  "name": "opencompanion",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "main": "dist/cli.js",
  "bin": {
    "opencompanion": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx --env-file-if-exists=../../.env ./src/cli.ts serve --if-paired",
    "cli": "tsx --env-file-if-exists=../../.env ./src/cli.ts",
    "build": "tsup",
    "standalone": "node scripts/build-standalone.mjs",
    "start": "node dist/cli.js",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@opencompanion/core": "workspace:*",
    "@opencompanion/protocol": "workspace:*",
    "conf": "^15.1.0",
    "picocolors": "^1.1.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "tsup": "^8.5.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "packageManager": "pnpm@11.1.2"
}
